{
    "name": "Savant Rust Container",
    "features": {},
    "build": {
        "dockerfile": "../Dockerfile",
        "args": {
            "REMOTE_USER": "${localEnv:USER}",
            "REMOTE_UID": "${localEnv:REMOTE_UID:1000}",
            "REMOTE_GID": "${localEnv:REMOTE_GID:1000}"
        },
        "target": "devcontainer",
        "context": "../.."
    },
    "runArgs": [
        "--runtime",
        "nvidia",
        "--gpus",
        "all",
        "-e",
        "AARCH64_IGPU=1"
    ],
    "remoteEnv": {
        "DISPLAY": null,
        "EGL_PLATFORM": "device",
        "SCCACHE_CACHE_SIZE": "2G"
    },
    "remoteUser": "${localEnv:USER}",
    "mounts": [
        "source=home-dir-vol,target=/home/${localEnv:USER},type=volume",
        "source=cargo-target-vol,target=/workspaces/savant-rs/target,type=volume"
    ],
    "customizations": {
        "vscode": {
            "settings": {},
            "extensions": [
                "ms-python.python",
                "ms-azuretools.vscode-docker",
                "rust-lang.rust-analyzer",
                "tamasfe.even-better-toml"
            ]
        }
    },
    "forwardPorts": [
        3000
    ],
    "postCreateCommand": "echo 'Dev container ready! Import .envrc to the shell to load the required environment variables.'",
    "postStartCommand": "find ~/.cursor-server/bin ~/.vscode-server/bin -maxdepth 1 -mindepth 1 -type d 2>/dev/null | sort | head -n -1 | xargs rm -rf 2>/dev/null; rm -rf /tmp/ds-mini /tmp/savant-check-target /tmp/enc-check 2>/dev/null; echo 'Cleaned stale IDE server versions and temp data.'"
}