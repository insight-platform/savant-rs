# Skia prebuilt binaries — version must match skia-safe in Cargo.toml (workspace).
# Update SKIA_BINARIES_VERSION + SKIA_BINARIES_HASH when bumping skia-safe.
# Binary releases: https://github.com/rust-skia/skia-binaries/releases
#
# Usage:
#   - direnv users: `direnv allow` once; all cargo/make commands work automatically.
#   - Docker (no direnv): add to ~/.bashrc:
#       source /workspaces/savant-rs/.envrc
SKIA_BINARIES_VERSION="0.93.1"
SKIA_BINARIES_HASH="319323662b1685a112f5"
SKIA_BINARIES_FEATURES="egl-gl-jpegd-jpege-pdf-skottie-svg-textlayout-vulkan-wayland-webpd-webpe-x11"

# Verify binary version strictly matches skia-safe in Cargo.toml.
# Uses return 1 (not exit 1) so sourcing from ~/.bashrc does not kill the shell.
_ENVRC_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
_CRATE_VERSION=$(grep '^skia-safe' "${_ENVRC_DIR}/Cargo.toml" | sed 's/.*version = "\([^"]*\)".*/\1/')
if [ "$SKIA_BINARIES_VERSION" != "$_CRATE_VERSION" ]; then
    echo "ERROR: SKIA_BINARIES_VERSION (${SKIA_BINARIES_VERSION}) does not match skia-safe = \"${_CRATE_VERSION}\" in Cargo.toml" >&2
    echo "       Update SKIA_BINARIES_VERSION + SKIA_BINARIES_HASH in .envrc to match." >&2
    unset _ENVRC_DIR _CRATE_VERSION SKIA_BINARIES_VERSION SKIA_BINARIES_HASH SKIA_BINARIES_FEATURES
    return 1
fi
unset _ENVRC_DIR _CRATE_VERSION

case "$(uname -m)" in
    aarch64) _SKIA_ARCH="aarch64-unknown-linux-gnu" ;;
    x86_64)  _SKIA_ARCH="x86_64-unknown-linux-gnu"  ;;
    *)       _SKIA_ARCH="" ;;
esac

if [ -n "$_SKIA_ARCH" ]; then
    export SKIA_BINARIES_URL="https://github.com/rust-skia/skia-binaries/releases/download/${SKIA_BINARIES_VERSION}/skia-binaries-${SKIA_BINARIES_HASH}-${_SKIA_ARCH}-${SKIA_BINARIES_FEATURES}.tar.gz"
    echo "SKIA_BINARIES_URL: $SKIA_BINARIES_URL"
fi
unset _SKIA_ARCH SKIA_BINARIES_VERSION SKIA_BINARIES_HASH SKIA_BINARIES_FEATURES

export SCCACHE_CACHE_SIZE="2G"